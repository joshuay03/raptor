#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"

argv = ARGV.dup

options = { fast: false, update_readme: false }
OptionParser.new do |opts|
  opts.banner = "Usage: bin/benchmark [--fast] [--update-readme]"
  opts.on("--fast", "Use short warmup/measurement windows for quick iteration") do
    options[:fast] = true
  end
  opts.on("--update-readme", "Replace the README's (Micro) Benchmarks section with the results") do
    options[:update_readme] = true
  end
end.parse!

unless File.exist?("/.dockerenv")
  exec(File.expand_path("dev", __dir__), "bin/#{File.basename(__FILE__)}", *argv)
end

require "fileutils"
require "open3"
require "socket"
require "tempfile"
require "timeout"

require_relative "../lib/raptor/version"

system("bundle", "update", "puma", "falcon", exception: true)
system("bundle", "exec", "rake", "compile", "bpf:compile", exception: true)

WORKERS = 4
THREADS = 3
HEY_CONNECTIONS = 48
H2LOAD_CONNECTIONS = 16
H2LOAD_STREAMS = 3
H1_PORT = 9292
H2_PORT = 9443
CERT_PATH = "tmp/bench.crt"
KEY_PATH = "tmp/bench.key"
README_PATH = File.expand_path("../README.md", __dir__)
BENCHMARKS_SECTION_PATTERN = /## \(Micro\) Benchmarks.*?(?=\n## |\z)/m

WORKLOADS = {
  io: { label: "IO", fixture: "test/fixtures/bench_io.ru" },
  cpu: { label: "CPU", fixture: "test/fixtures/bench_cpu.ru" }
}

if options[:fast]
  RUNS_PER_MODE = 1
  WARMUP_SECONDS = 2
  MAIN_SECONDS = 5
  BETWEEN_RUNS_SECONDS = 0
else
  RUNS_PER_MODE = 5
  WARMUP_SECONDS = 3
  MAIN_SECONDS = 20
  BETWEEN_RUNS_SECONDS = 5
end

def require_tool(name)
  return if system("which #{name} > /dev/null 2>&1")

  abort "Missing required tool: #{name.inspect}. Run bin/setup."
end

require_tool("hey")
require_tool("h2load")
require_tool("openssl")

def log(message)
  warn "[bench] #{message}"
end

def generate_cert
  FileUtils.mkdir_p(File.dirname(CERT_PATH))
  cmd = [
    "openssl", "req", "-x509", "-newkey", "rsa:2048",
    "-keyout", KEY_PATH, "-out", CERT_PATH,
    "-days", "365", "-nodes",
    "-subj", "/CN=localhost",
    "-addext", "subjectAltName=DNS:localhost,IP:127.0.0.1"
  ]
  return if system(*cmd, out: File::NULL, err: File::NULL)

  abort "Failed to generate TLS cert/key."
end

def wait_for_port(port, timeout: 30)
  deadline = Time.now + timeout
  loop do
    begin
      TCPSocket.new("127.0.0.1", port).close
      return
    rescue Errno::ECONNREFUSED, Errno::ECONNRESET
      raise "Port #{port} never opened" if Time.now > deadline

      sleep 0.2
    end
  end
end

def wait_for_port_free(port, timeout: 30)
  deadline = Time.now + timeout
  loop do
    begin
      TCPSocket.new("127.0.0.1", port).close
      raise "Port #{port} still in use" if Time.now > deadline

      sleep 0.5
    rescue Errno::ECONNREFUSED, Errno::ECONNRESET
      return
    end
  end
end

def start_server(cmd, ports)
  log_file = Tempfile.new(["server-", ".log"])
  pid = spawn(*cmd, [:out, :err] => log_file.path, pgroup: true)
  ports.each { |port| wait_for_port(port) }
  [pid, log_file]
rescue => error
  Process.kill("TERM", -pid) if pid
  warn File.read(log_file.path)
  log_file.close!
  raise error
end

def stop_server(pid, ports, log_file)
  Process.kill("TERM", -pid) rescue nil
  begin
    Timeout.timeout(5) { Process.wait(pid) }
  rescue Timeout::Error
    Process.kill("KILL", -pid) rescue nil
    Process.wait(pid) rescue nil
  rescue Errno::ESRCH, Errno::ECHILD
  end
  Process.kill("KILL", -pid) rescue nil
  Process.waitall rescue nil
  ports.each { |port| wait_for_port_free(port) }
  log_file.close!
end

def with_server(label, cmd, ports)
  log "Starting #{label}"
  pid, log_file = start_server(cmd, ports)
  yield
rescue => error
  warn File.read(log_file.path) if pid
  raise error
ensure
  log "Stopping #{label}"
  stop_server(pid, ports, log_file) if pid
end

def run_hey(url:, keep_alive:)
  keep_alive_flag = keep_alive ? nil : "-disable-keepalive"
  warmup = ["hey", "-c", HEY_CONNECTIONS.to_s, "-z", "#{WARMUP_SECONDS}s", keep_alive_flag, url].compact
  warmup_output, warmup_status = Open3.capture2(*warmup)
  abort_with_output "hey warmup failed", warmup_output unless warmup_status.success?
  check_hey_clean(warmup_output, "warmup")

  measure = ["hey", "-c", HEY_CONNECTIONS.to_s, "-z", "#{MAIN_SECONDS}s", keep_alive_flag, url].compact
  output, status = Open3.capture2(*measure)
  abort_with_output "hey failed", output unless status.success?
  check_hey_clean(output, "measurement")

  req_s_match = output.match(/Requests\/sec:\s+([\d.]+)/)
  abort_with_output "could not parse hey req/s", output unless req_s_match

  p95_match = output.match(/95%+\s+in\s+([\d.]+)/)
  abort_with_output "could not parse hey p95", output unless p95_match

  { req_s: req_s_match[1].to_f, p95_ms: p95_match[1].to_f * 1000 }
end

def check_hey_clean(output, phase)
  abort_with_output "hey #{phase} produced errors", output if output.include?("Error distribution:")

  responses = output.scan(/\[(\d{3})\]\s+\d+ responses/).flatten
  abort_with_output "hey #{phase} received no responses", output if responses.empty?

  non_2xx = responses.reject { |code| code.start_with?("2") }
  abort_with_output "hey #{phase} received non-2xx responses (#{non_2xx.uniq.join(', ')})", output if non_2xx.any?
end

def run_h2load(url:)
  warmup = ["h2load", "-c", H2LOAD_CONNECTIONS.to_s, "-m", H2LOAD_STREAMS.to_s, "-D", WARMUP_SECONDS.to_s, url]
  warmup_output, warmup_status = Open3.capture2(*warmup)
  abort_with_output "h2load warmup failed", warmup_output unless warmup_status.success?
  check_h2load_clean(warmup_output, "warmup")

  log_file = Tempfile.new(["h2load", ".log"])
  log_file.close
  begin
    measure = ["h2load", "-c", H2LOAD_CONNECTIONS.to_s, "-m", H2LOAD_STREAMS.to_s, "-D", MAIN_SECONDS.to_s, "--log-file", log_file.path, url]
    output, status = Open3.capture2(*measure)
    abort_with_output "h2load failed", output unless status.success?
    check_h2load_clean(output, "measurement")

    req_s_match = output.match(/finished in [\d.]+s,\s+([\d.]+) req\/s/)
    abort_with_output "could not parse h2load req/s", output unless req_s_match

    latencies_us = File.readlines(log_file.path).map { |line| line.split[2].to_i }.sort
    abort_with_output "h2load log file empty", output if latencies_us.empty?
    p95_index = (latencies_us.length * 0.95).ceil - 1
    p95_ms = latencies_us[p95_index] / 1000.0

    { req_s: req_s_match[1].to_f, p95_ms: p95_ms }
  ensure
    log_file.unlink
  end
end

def check_h2load_clean(output, phase)
  requests = output.match(/(\d+) succeeded, (\d+) failed, (\d+) errored, (\d+) timeout/)
  abort_with_output "could not parse h2load requests summary", output unless requests

  succeeded, failed, errored, timeout = requests.captures.map(&:to_i)
  abort_with_output "h2load #{phase} reported #{failed} failed, #{errored} errored, #{timeout} timeout", output if failed > 0 || errored > 0 || timeout > 0
  abort_with_output "h2load #{phase} received no successful responses", output if succeeded == 0

  status_codes = output.match(/status codes: \d+ 2xx, (\d+) 3xx, (\d+) 4xx, (\d+) 5xx/)
  abort_with_output "could not parse h2load status codes", output unless status_codes

  threes, fours, fives = status_codes.captures.map(&:to_i)
  abort_with_output "h2load #{phase} received non-2xx responses: #{threes} 3xx, #{fours} 4xx, #{fives} 5xx", output if threes > 0 || fours > 0 || fives > 0
end

def abort_with_output(message, output)
  warn output
  abort message
end

def benchmark(label)
  log "Benchmarking #{label}"
  results = []
  RUNS_PER_MODE.times do |index|
    result = yield
    results << result
    log "  Run #{index + 1}/#{RUNS_PER_MODE}: #{result[:req_s].round} req/s, p95 #{format('%.2f', result[:p95_ms])} ms"
    sleep BETWEEN_RUNS_SECONDS if index < RUNS_PER_MODE - 1
  end
  median = {
    req_s: median_of(results.map { |result| result[:req_s] }),
    p95_ms: median_of(results.map { |result| result[:p95_ms] })
  }
  log "  Median: #{median[:req_s].round} req/s, p95 #{format('%.2f', median[:p95_ms])} ms" if results.length > 1
  median
end

def median_of(values)
  values.sort[values.length / 2]
end

def format_req_s(value)
  rounded = (value / 10.0).round * 10
  thousands = rounded / 1000.0
  "#{format('%.2f', thousands)}k req/s"
end

def format_p95_ms(value)
  "#{format('%.2f', value)} ms"
end

def format_delta(subject, baseline)
  delta = ((subject - baseline) / baseline) * 100
  sign = delta >= 0 ? "+" : ""
  "#{sign}#{format('%.1f', delta)}%"
end

def render_markdown_row(cells, widths)
  "| " + cells.map { |key, value| value.ljust(widths[key]) }.join(" | ") + " |"
end

def puma_version
  output, status = Open3.capture2("bundle", "exec", "ruby", "-e", "require 'puma/const'; puts Puma::Const::PUMA_VERSION")
  abort "could not read Puma version" unless status.success?

  output.strip
end

def falcon_version
  output, status = Open3.capture2("bundle", "exec", "ruby", "-e", "require 'falcon/version'; puts Falcon::VERSION")
  abort "could not read Falcon version" unless status.success?

  output.strip
end

def raptor_cmd(fixture)
  [
    "bundle", "exec", "raptor",
    "-w", WORKERS.to_s, "-t", THREADS.to_s,
    "-b", "tcp://0.0.0.0:#{H1_PORT}",
    "-b", "ssl://0.0.0.0:#{H2_PORT}?cert=#{CERT_PATH}&key=#{KEY_PATH}",
    fixture
  ]
end

def puma_cmd(fixture)
  [
    "bundle", "exec", "puma",
    "-w", WORKERS.to_s, "-t", "#{THREADS}:#{THREADS}",
    "-b", "tcp://0.0.0.0:#{H1_PORT}",
    fixture
  ]
end

def falcon_cmd(fixture)
  [
    "bundle", "exec", "falcon", "serve",
    "--count", WORKERS.to_s,
    "--bind", "http://0.0.0.0:#{H1_PORT}",
    "--config", fixture
  ]
end

def bench_h1(server_label, cmd, ports, workload_label, keep_alive:)
  with_server(server_label, cmd, ports) do
    benchmark("#{server_label} HTTP/1.1#{keep_alive ? ' keep-alive' : ''} (#{workload_label})") do
      run_hey(url: "http://127.0.0.1:#{H1_PORT}/", keep_alive: keep_alive)
    end
  end
end

def bench_h2(server_label, cmd, ports, workload_label)
  with_server(server_label, cmd, ports) do
    benchmark("#{server_label} HTTP/2 (#{workload_label})") do
      run_h2load(url: "https://127.0.0.1:#{H2_PORT}/")
    end
  end
end

generate_cert

results = {}

WORKLOADS.each do |workload, config|
  fixture = config[:fixture]
  label = config[:label]
  raptor_ports = [H1_PORT, H2_PORT]
  puma_ports = [H1_PORT]
  falcon_ports = [H1_PORT]

  results[workload] = {
    raptor_h1: bench_h1("Raptor", raptor_cmd(fixture), raptor_ports, label, keep_alive: false),
    raptor_h1_ka: bench_h1("Raptor", raptor_cmd(fixture), raptor_ports, label, keep_alive: true),
    raptor_h2: bench_h2("Raptor", raptor_cmd(fixture), raptor_ports, label),
    puma_h1: bench_h1("Puma", puma_cmd(fixture), puma_ports, label, keep_alive: false),
    puma_h1_ka: bench_h1("Puma", puma_cmd(fixture), puma_ports, label, keep_alive: true),
    falcon_h1: bench_h1("Falcon", falcon_cmd(fixture), falcon_ports, label, keep_alive: false),
    falcon_h1_ka: bench_h1("Falcon", falcon_cmd(fixture), falcon_ports, label, keep_alive: true)
  }
end

PROTOCOLS = [
  { label: "HTTP/1.1", raptor_key: :raptor_h1, puma_key: :puma_h1, falcon_key: :falcon_h1 },
  { label: "HTTP/1.1 (keep-alive)", raptor_key: :raptor_h1_ka, puma_key: :puma_h1_ka, falcon_key: :falcon_h1_ka },
  { label: "HTTP/2", raptor_key: :raptor_h2, puma_key: nil, falcon_key: nil }
]

rows = []
PROTOCOLS.each do |protocol|
  WORKLOADS.each do |workload, config|
    raptor_value = results[workload][protocol[:raptor_key]]
    puma_value = protocol[:puma_key] ? results[workload][protocol[:puma_key]] : nil
    falcon_value = protocol[:falcon_key] ? results[workload][protocol[:falcon_key]] : nil
    rows << {
      protocol: protocol[:label],
      workload: config[:label],
      raptor_req_s: format_req_s(raptor_value[:req_s]),
      raptor_p95: format_p95_ms(raptor_value[:p95_ms]),
      puma_req_s: puma_value ? format_req_s(puma_value[:req_s]) : "N/A",
      puma_p95: puma_value ? format_p95_ms(puma_value[:p95_ms]) : "N/A",
      vs_puma_req_s: puma_value ? format_delta(raptor_value[:req_s], puma_value[:req_s]) : "-",
      vs_puma_p95: puma_value ? format_delta(raptor_value[:p95_ms], puma_value[:p95_ms]) : "-",
      falcon_req_s: falcon_value ? format_req_s(falcon_value[:req_s]) : "N/A",
      falcon_p95: falcon_value ? format_p95_ms(falcon_value[:p95_ms]) : "N/A",
      vs_falcon_req_s: falcon_value ? format_delta(raptor_value[:req_s], falcon_value[:req_s]) : "-",
      vs_falcon_p95: falcon_value ? format_delta(raptor_value[:p95_ms], falcon_value[:p95_ms]) : "-"
    }
  end
end

HEADERS = {
  protocol: "Protocol",
  workload: "Workload",
  raptor_req_s: "Raptor req/s",
  raptor_p95: "Raptor p95",
  puma_req_s: "Puma req/s",
  puma_p95: "Puma p95",
  vs_puma_req_s: "vs Puma req/s",
  vs_puma_p95: "vs Puma p95",
  falcon_req_s: "Falcon req/s",
  falcon_p95: "Falcon p95",
  vs_falcon_req_s: "vs Falcon req/s",
  vs_falcon_p95: "vs Falcon p95"
}
widths = HEADERS.transform_values(&:length)
rows.each do |row|
  row.each { |key, value| widths[key] = [widths[key], value.length].max }
end

separator = HEADERS.to_h { |key, _| [key, "-" * widths[key]] }
table_lines = [render_markdown_row(HEADERS, widths), render_markdown_row(separator, widths)]
rows.each { |row| table_lines << render_markdown_row(row, widths) }

section = <<~MD
  ## (Micro) Benchmarks

  Raptor #{Raptor::VERSION} vs Puma #{puma_version} vs Falcon #{falcon_version}, median of #{RUNS_PER_MODE} runs across two workload profiles: IO-bound (5-10 short sleeps
  interleaved with small CPU work per request, total sleep 2.5-15ms, simulating a request with several DB or cache calls)
  and CPU-bound (3-5 chunks of JSON item building interleaved with sub-100µs sleeps per request, total items 450-1500,
  simulating a request that does most of its work in Ruby with a few near-zero-cost cache hits).

  #{table_lines.join("\n")}

  > #{RUBY_DESCRIPTION}
  > #{WORKERS} workers, #{THREADS} threads, #{HEY_CONNECTIONS} concurrent connections

  See [bin/benchmark](bin/benchmark) for more details.
MD

puts
puts section

if options[:update_readme]
  readme = File.read(README_PATH)
  abort "Could not find existing (Micro) Benchmarks section in README.md" unless readme.match?(BENCHMARKS_SECTION_PATTERN)

  File.write(README_PATH, readme.sub(BENCHMARKS_SECTION_PATTERN, section))
  log "README.md updated."
end
